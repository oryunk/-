# backend/.env.example 을 복사해 `backend/.env` 로 두고 값만 채우세요. `.env` 는 Git에 올리지 마세요.

# ── MySQL (로그인·모의투자 DB)
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# ── Flask (세션·쿠키용, 운영에서는 긴 임의 문자열 권장)
FLASK_SECRET_KEY=
FLASK_HOST=
AUTH_PORT=
OPENAI_API_KEY=

# ── Google OAuth (사용자 로그인 — KIS tokenP 와 별개)
# Cloud Console → OAuth 2.0 클라이언트(웹) → 승인된 리디렉션 URI 와 GOOGLE_REDIRECT_URI 일치
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_LOGIN_SUCCESS_URL=

# ── 회원가입 이메일 인증코드 (SMTP) — 상세: backend/docs/EMAIL_SMTP_SETUP.md
# 발신 계정 1개만 선택. 가입자는 네이버·구글·다음·카카오·네이트 등 아무 도메인이나 수신 가능.
#
# [네이버] SMTP_HOST=smtp.naver.com  SMTP_PORT=587  SMTP_USE_TLS=true
# [구글] SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USE_TLS=true  (SMTP_PASSWORD=앱비밀번호)
# [다음] SMTP_HOST=smtp.daum.net   SMTP_PORT=465  SMTP_USE_TLS=false
# [네이트] SMTP_HOST=smtp.mail.nate.com SMTP_PORT=587 SMTP_USE_TLS=true
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=
EMAIL_CODE_TTL_MIN=
EMAIL_CODE_RESEND_SEC=

# ── 한국투자 Open API (시세·지수). 여기만 채워도 체감 품질이 가장 큼. 비우면 yfinance 등 폴백.
KIS_APP_KEY=
KIS_APP_SECRET=

# ── 선택 (비워도 됨, 기본값 사용)
# GPT_MODEL=gpt-5.4-mini
# KIS_USE_PROD=true
# 장외·주말에도 DB 시세 동기화(yfinance)는 돌리고, KIS 실시간만 끄려면 true 유지(기본). 전부 끄려면 false.
# LIVE_PRICE_BLOCK_OFFHOURS_FETCH=true
# 장외: DB 일봉 최신 날짜가 오늘 기준 N일 이상 지나면 yfinance 보강 대상 (기본 2, 0이면 비활성)
# LIVE_PRICE_OFFHOURS_STALE_DAYS=2
# 차트: 토스 스타일(1일/1주/1개월/1년 = 일/주/월/년봉), KIS+DB 우선 (false 면 yfinance 만)
# CHART_USE_KIS=true
# MOCK_INITIAL_CASH=1000000
# 투자자 동향(pykrx): KRX 데이터포털 로그인 (없으면 KIS_APP_KEY 로 자동 폴백)
# KRX_ID=
# KRX_PW=
# 루미 AI 챗봇 (false 면 FAQ만)
# LUMI_CHAT_ENABLED=true
