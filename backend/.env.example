# 이 파일을 복사해 `.env` 로 저장한 뒤, 본인 PC의 MySQL 비밀번호 등을 채웁니다.
# GitHub에는 `.env.example` 만 올리고 `.env` 는 절대 커밋하지 않습니다.

MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=stock_db

FLASK_SECRET_KEY=change-me-to-a-long-random-string
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# 선택: Gemini 분석 API
GEMINI_API_KEY=
