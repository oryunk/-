# backend/.env.example 을 복사해 `backend/.env` 로 두고 값만 채우세요. `.env` 는 Git에 올리지 마세요.

# ── MySQL (로그인·모의투자 DB)
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# ── Flask (세션·쿠키용, 운영에서는 긴 임의 문자열 권장)
FLASK_SECRET_KEY=
FLASK_HOST=
AUTH_PORT=
OPENAI_API_KEY=

# ── Google OAuth (사용자 로그인 — KIS tokenP 와 별개)
# 상세: backend/docs/GOOGLE_OAUTH_SETUP.md
# Cloud Console → OAuth 2.0 클라이언트(웹) → 승인된 리디렉션 URI 와 GOOGLE_REDIRECT_URI 문자 단위 일치
# 로컬·AWS 둘 다 쓰면 Console에 URI 2개 등록, 서버별 .env 에는 그 서버 callback 하나만
# 로컬 예: GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/api/auth/google/callback
# AWS 예:  GOOGLE_REDIRECT_URI=http://YOUR_HOST:5000/api/auth/google/callback
# 점검: python scripts/check_google_oauth_env.py  또는 GET /api/auth/google/status
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_LOGIN_SUCCESS_URL=/주린닷컴홈피.html

# ── 회원가입 이메일 인증코드 (SMTP) — 상세: backend/docs/EMAIL_SMTP_SETUP.md
# 발신 계정 1개만 선택. 가입자는 네이버·구글·다음·카카오·네이트 등 아무 도메인이나 수신 가능.
#
# [네이버] SMTP_HOST=smtp.naver.com  SMTP_PORT=587  SMTP_USE_TLS=true
# [구글] SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USE_TLS=true  (SMTP_PASSWORD=앱비밀번호)
# [다음] SMTP_HOST=smtp.daum.net   SMTP_PORT=465  SMTP_USE_TLS=false
# [네이트] SMTP_HOST=smtp.mail.nate.com SMTP_PORT=587 SMTP_USE_TLS=true
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=
EMAIL_CODE_TTL_MIN=
EMAIL_CODE_RESEND_SEC=

# ── 한국투자 Open API (시세·지수). 여기만 채워도 체감 품질이 가장 큼. 비우면 yfinance 등 폴백.
KIS_APP_KEY=
KIS_APP_SECRET=

# ── 선택 (비워도 됨, 기본값 사용)
# GPT_MODEL=gpt-4o-mini
# KIS_USE_PROD=true
# 장외·주말에도 DB 시세 동기화(yfinance)는 돌리고, KIS 실시간만 끄려면 true 유지(기본). 전부 끄려면 false.
# LIVE_PRICE_BLOCK_OFFHOURS_FETCH=true
# 장외: DB 일봉 최신 날짜가 오늘 기준 N일 이상 지나면 yfinance 보강 대상 (기본 2, 0이면 비활성)
# LIVE_PRICE_OFFHOURS_STALE_DAYS=2
# 차트: 토스 스타일(1일/1주/1개월/1년 = 일/주/월/년봉), KIS+DB 우선 (false 면 yfinance 만)
# CHART_USE_KIS=true
# MOCK_INITIAL_CASH=5000000
# 루미 AI 챗봇 (false 면 FAQ만)
# LUMI_CHAT_ENABLED=true

# ── Redis (호가·실시간 시세 캐시). 비우거나 REDIS_CACHE_ENABLED=false 면 메모리 캐시만 사용.
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_CACHE_ENABLED=true
# LIVE_PRICE_REDIS_TTL_SEC=300
# MARKET_INDICES_REDIS_TTL_SEC=60
# TRADED_VALUE_RANK_REDIS_TTL_SEC=12
# LIVE_PRICES_LIST_REDIS_TTL_SEC=8
# MOCK_ASKING_CACHE_TTL_SEC=15
# MOCK_ASKING_STALE_FALLBACK_SEC=180
# MOCK_ASKING_FETCH_LOCK_SEC=5
# KIS_ASKING_MIN_GAP_SEC=1.0
# MYSQL_CONNECT_TIMEOUT=8
# MYSQL_READ_TIMEOUT=20
